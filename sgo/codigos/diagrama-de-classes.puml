@startuml diagrama-de-classes

skinparam classAttributeIconSize 0
skinparam class {
  BackgroundColor #EEF4FF
  BorderColor #3366CC
  ArrowColor #3366CC
  FontSize 13
}
skinparam stereotypeCBackgroundColor #CCDDFF

class Pais {
  - id: Long
  - nome: String
  - codigo: String
  - sigla: String
  + getNome(): String
  + getCodigo(): String
  + getAtletas(): List<Atleta>
  + getTotalMedalhas(): int
}

class Atleta {
  - id: Long
  - nome: String
  - dataNascimento: Date
  - genero: String
  - pais: Pais
  + getNome(): String
  + getPais(): Pais
  + getInscricoes(): List<Inscricao>
  + getResultados(): List<Resultado>
}

class Competicao {
  - id: Long
  - modalidade: String
  - data: Date
  - horario: Time
  - status: StatusCompeticao
  + getModalidade(): String
  + getLocal(): Local
  + getAtletasInscritos(): List<Atleta>
  + getResultado(): Resultado
  + iniciar(): void
  + encerrar(): void
}

class Local {
  - id: Long
  - nome: String
  - endereco: String
  - capacidade: int
  - disponivel: boolean
  + getNome(): String
  + isDisponivel(data: Date, horario: Time): boolean
  + alocar(competicao: Competicao): void
  + liberar(): void
}

class Inscricao {
  - id: Long
  - dataInscricao: Date
  - status: StatusInscricao
  - atleta: Atleta
  - competicao: Competicao
  + confirmar(): void
  + cancelar(): void
  + getAtleta(): Atleta
  + getCompeticao(): Competicao
}

class Resultado {
  - id: Long
  - dataRegistro: Date
  - competicao: Competicao
  + getOuro(): Atleta
  + getPrata(): Atleta
  + getBronze(): Atleta
  + registrar(ouro: Atleta, prata: Atleta, bronze: Atleta): void
}

class Medalha {
  - id: Long
  - tipo: TipoMedalha
  - atleta: Atleta
  - pais: Pais
  - resultado: Resultado
  + getTipo(): TipoMedalha
  + getAtleta(): Atleta
}

class RelatorioMedalhas {
  - id: Long
  - dataGeracao: Date
  - periodo: String
  + gerar(): void
  + exportar(formato: String): File
  + getRankingPaises(): List<Pais>
}

enum StatusCompeticao {
  AGENDADA
  EM_ANDAMENTO
  ENCERRADA
  CANCELADA
}

enum StatusInscricao {
  PENDENTE
  CONFIRMADA
  CANCELADA
}

enum TipoMedalha {
  OURO
  PRATA
  BRONZE
}

Atleta "n" --> "1" Pais : representa
Atleta "1" --> "n" Inscricao : possui
Competicao "1" --> "n" Inscricao : contém
Competicao "1" --> "1" Local : ocorre em
Competicao "1" --> "0..1" Resultado : gera
Resultado "1" --> "3" Medalha : distribui
Medalha "n" --> "1" Atleta : concedida a
Medalha "n" --> "1" Pais : pertence a
RelatorioMedalhas ..> Medalha : consulta
RelatorioMedalhas ..> Pais : classifica
Competicao --> StatusCompeticao
Inscricao --> StatusInscricao
Medalha --> TipoMedalha

@enduml
